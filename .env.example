# Neighborhood Life — environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.

# --- Supabase (public) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- Supabase (server-only) ---
# Service role key bypasses RLS — server-side only, never expose to the browser.
# Used by the OSM seed job (scripts/seed-osm.ts / the "Seed OSM data" Action).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Seed job project URL (falls back to NEXT_PUBLIC_SUPABASE_URL if unset).
SUPABASE_URL="https://your-project.supabase.co"

# --- Map tiles ---
# MapLibre vector-tile STYLE URL for the report map. Do NOT use the public OSM
# tile server in production (CLAUDE.md §12.1). Use MapTiler (free tier) or a
# self-hosted PMTiles style. Example (MapTiler):
#   https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_KEY
# Public (in the browser) — restrict the key by domain in the provider dashboard.
NEXT_PUBLIC_MAP_TILES_URL=""

# --- Google Places (server-only) ---
# Used for LAZY, on-demand business enrichment only (CLAUDE.md §31.1):
# fetched when a user opens a business, never bulk-scraped, max 5 reviews/place,
# isolated from the permanent record, cached only within Google's allowed window.
GOOGLE_PLACES_API_KEY=""

# --- Geocoding (server-only) ---
# Do NOT use the public Nominatim service as a production backend (CLAUDE.md §15.6).
GEOCODING_PROVIDER="nominatim-selfhost"
GEOCODING_API_KEY=""

# --- Walk isochrones (server-only) ---
# openrouteservice key for real 10/15-min walk reach (CLAUDE.md §15.7). Without
# it, the report shows a clearly-labeled straight-line walk-time estimate.
# Free key: https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=""
